<div title="<%= t('page_actions')%>" class="d-flex justify-content-end">

  <% if record.respond_to?(:cite) %>
    <div class="large-badge text-center resource p-1">
      <%= form_tag app_prefix("/cite"), :id => 'cite_sub' do |f| %>
        <%= hidden_field_tag 'uri', record.uri %>
        <%= hidden_field_tag 'cite', record.cite %>
        <button type="submit" class="btn page_action request btn-default">
          <i class="fa fa-book"></i>
          <span class="action-text"><%= t('actions.cite') %></span>
        </button>
      <% end %>
    </div>
  <% end %>

  <% if ['resource', 'archival_object'].include?(record.primary_type) %>
    <div class="large-badge text-center resource p-1">
      <%= form_tag(app_prefix("/repositories/#{params[:rid]}/resources/#{params[:id]}/pdf"), method: 'post', id:'print_form', target: "_blank") do %>
	<button id="print_button" class="btn btn-default page_action print">
	    <i class="fa-regular fa-file"></i>
	    <span class="action-text">Download PDF</span>
	</button>
      <% end %>
    </div>
  <% end %>

  <% unless record.primary_type.start_with?('agent') %>
    <div class="large-badge text-center resource p-1">
      <a href="https://ask.loc.gov/" class="btn btn-default page_action" target="_blank" title="<%= t('actions.ask_a_librarian', default: 'Ask a Librarian') %>">
        <i class="fa fa-comment"></i>
        <span class="action-text"><%= t('actions.ask_a_librarian', default: 'Ask a Librarian') %></span>
      </a>
    </div>
  <% end %>

</div>
