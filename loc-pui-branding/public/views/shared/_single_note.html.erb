<% heading_size = 'h2' if heading_size.blank? %>
<% sub_heading_size = 'h3' if sub_heading_size.blank? %>

<% 
   heading_text = note_struct['label'].presence || note_struct['type']
%>

<% # Display the note if there's either top-level text or subnotes %>
<% if note_struct['note_text'].present? || note_struct['subnotes'].present? %>
  <div class="<%= type %> single_note">
    
    <% unless (defined?(notitle) && notitle) || heading_text.blank? %>
      <<%= heading_size %>><%= heading_text.html_safe %></<%= heading_size %>>
    <% end %>

    <% if note_struct.has_key?('subnotes') && note_struct['subnotes'].any? %>
      <% note_struct['subnotes'].each do |subnote| %>
        <div class="subnote mr-2">
          <% if subnote['jsonmodel_type'] == 'note_citation' %>
            <<%= sub_heading_size %>><%= t('actions.cite') %></<%= sub_heading_size %>>
          <% elsif subnote['_title'] && subnote['_title'].to_s.strip != heading_text.to_s.strip %>
            <<%= sub_heading_size %>><%= subnote['_title'].html_safe %></<%= sub_heading_size %>>
          <% elsif subnote['_inline_label'] %>
            <span class='inline-label'><%= subnote['_inline_label'] %></span>
          <% end %>

          <%= render partial: 'shared/note_content',
                     locals: {
                       content: subnote['_text'],
                       is_inherited: note_struct['is_inherited'],
                       type: type,
                       calling_partial: calling_partial
                     } %>
        </div>
      <% end %>
    <% else %>
      <%= render partial: 'shared/note_content',
                 locals: {
                   content: note_struct['note_text'],
                   is_inherited: note_struct['is_inherited'],
                   type: type,
                   calling_partial: calling_partial
                 } %>
    <% end %>

  </div>
<% end %>
