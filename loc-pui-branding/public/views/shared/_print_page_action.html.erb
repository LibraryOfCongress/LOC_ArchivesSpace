<% if AppConfig[:pui_max_concurrent_pdfs] > 0 %>
    <%= form_tag(app_prefix("/repositories/#{params[:rid]}/resources/#{params[:id]}/pdf"), method: 'post', :id => 'print_form') do %>
        <%# ... hidden fields ... %>
        <button id="print_button" class="btn btn-default page_action print">
            <i class="fa-regular fa-file"></i>
            <span class="action-text">Download PDF</span>
        </button>
    <% end %>
<% end %>