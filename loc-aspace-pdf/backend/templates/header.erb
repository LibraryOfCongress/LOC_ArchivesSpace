<head>
  <meta charset="utf-8" />
  <style>
    body {
  font-family: <%= AppConfig[:pui_pdf_font_name] %>;
  line-height: <%= AppConfig[:pui_pdf_paragraph_line_height] %>;
  font-size: 9pt;
  line-height: 1.2;
    }

   .title-page {
  page-break-after: always;
  position: relative;
  height: 58em;
    }

    .toc-page {
  page-break-after: always;
    }

   span.title {
     font-style: italic;
   }

   .title {
     line-height: 140%;
     line-height: <%= AppConfig[:pui_pdf_title_line_height] %>;
   }

   li {
     list-style-type: none;
     position: relative;
   }

   li::before {
       content: '•';
       position: absolute;
       left: -0.8em;          /* Adjust this value so that it appears where you want. */
       font-size: 1.1em;      /* Adjust this value so that it appears what size you want. */
   }

    div.logo {
  display: block;
  width: 100%;
  height: 250px;
  background-repeat: no-repeat;
  background-size: 100% auto;
  background-origin: content-box;
  background-position: 50% 50%;
    }

    .logo img {
       width: 200px;
    }

    ul.toc {
  list-style-type: none;
  margin-left: 0;
  padding-left: 0;
    }

    ul.toc li::before {
       content: none !important;
       position: absolute;
       left: 0;
       font-size: 1 em;
   }

    a {
  color: #3333FF;
    }

    .toc .level-1 { padding-left: 1em; }
    .toc .level-2 { padding-left: 2em; }
    .toc .level-3 { padding-left: 3em; }
    .toc .level-4 { padding-left: 4em; }
    .toc .level-5 { padding-left: 5em; }
    .toc .level-6 { padding-left: 6em; }
    .toc .level-7 { padding-left: 7em; }
    .toc .level-8 { padding-left: 8em; }
    .toc .level-9 { padding-left: 9em; }
    .toc .level-10 { padding-left: 10em; }

    .toc a {
  color: black;
  text-decoration: none;
    }


    ul.toc span.toc-entry a::after {
  content: leader('.');
    }

    ul.toc span.toc-page a::after {
  content: target-counter(attr(href), page);
    }

    a.record-title {
  color: black;
  font-weight: bold;
    }

    /* container layout / disable floats entirely.
       floats in Flying Saucer cause cross-record bleed in deeply
       nested structures. The box/folder labels render on their own line below
       the AO title */
    .ao-summary {
      width: 100%;
      float: none;
      display: block;
    }

    .ao-summary a.record-title {
      font-size: 100%;
      font-weight: bold;
    }

    .container-information {
      width: 100%;
      float: none;
      display: block;
      text-align: left;
      font-size: 80%;
      color: #333;
      margin: 2px 0 4px 0;
    }

    .container-information .box-area {
      display: block;
      float: none;
      width: auto;
    }
    .container-information .box-string,
    .container-information .folder-string {
      display: inline-block;
      float: none;
      margin: 0 8px 0 0;
      overflow: visible;
      text-align: left;
    }

    /* series-header gray banner */
    .first-post {
      padding-top: 4px;
      padding-bottom: 4px;
    }
    .first-post .container-information {
      margin-top: 4px;
      margin-bottom: 2px;
    }

    h3 {
  font-size: 11pt;
  margin-top: 0.6em;
  margin-left: 0;
  border-top-width: 2px;
  padding: 4px 0;
  border-top: 2px #000 solid;
  border-bottom: 1px #000 dotted;
  margin-left: -10px;
    }

    h3 + p {
       margin-left: 20px;
    }

    div#note-prefercite {
       border: 2px #000 solid;
       padding: 5px;
    }

    /* collection inventory header table | tighten and de-emphasize */
    table.collection-inventory-header {
      margin-top: 8px;
      margin-bottom: 2px;
      width: 100%;
    }

    table.collection-inventory-header td.title {
       width: 90%;
       text-align: left;
    }

    table.collection-inventory-header td.instance {
       width: 10%;
       text-align: left;
    }

    dl {
       overflow: hidden;
       margin: 0.23 em 0;
    }

    dt, dd { float: left; margin: 0; margin-top: 0.15em; }
    dt { clear: both; font-weight: bold; width: 20%; text-align: right; margin-right: 1em; }
    dd { width: 70%; }

    .title-block {
  /* border-bottom: solid 2px black; */
    }

    .bioghist dl { width: auto; }
    .bioghist dt { width: 110px; font-weight: bold; }
    .bioghist dd { width: 380px; margin-left: 120px; }

    .bioghist table th {
  white-space: nowrap;
    }

    div.title-text-block p {
  margin: 0;
    }

    .title-block h2 {
  border: 0;
    }

    .title-page .repository-information {
  position: absolute;
  bottom: 0;
  width: 95%;
  padding: 1em;
    }

    .repository-information > * {
  padding-left: 1em;
    }

    .repository-information > .repository-name {
  padding-left: 0;
    }

    .repository-address {
       line-height: 5px;
    }

    h2 {
  padding-top: 0.25em;
  padding-bottom: 0.25em;
  border-top: solid 2px #33;
  border-bottom: dotted 1px #333;
    }



    .print-record-border {
  padding-left: 0.5em;
  /* border: 1px solid #f00; */
  /* margin: 0; /*

  /* Get rid of annoying vertical whitespace */
  /* margin-top: -8px; */
  /* padding-top: 8px; */
  /* padding-bottom: 10px !important; */
    }

    .avoid-break {
  margin-top: 2px;
  break-inside: avoid;
  page-break-inside: avoid;
    }

    .print-record {
  margin-bottom: 0.15em;
  display: block;
  border-top: solid 1px #dedede;
  padding-top: 3px;
  padding-bottom: 4px;
    }

    .print-record-border.print-record.level-1 { padding-top: 0; margin-top: 0.4em; }

    .print-record-border.level-1 {
      margin: 2px;
    }

    .print-record-border.level-2 {
      margin-left: 8px;
    }

    .print-record-border.level-3 {
      margin-left: 12px;
    }

    .print-record-border.level-4 {
      margin-left: 16px;
    }

    .print-record-border.level-5,
    .print-record-border.level-6,
    .print-record-border.level-7,
    .print-record-border.level-8,
    .print-record-border.level-9,
    .print-record-border.level-10,
    .print-record-border.level-11,
    .print-record-border.level-12 {
      margin-left: 20px;
    }

    .print-record h3 {
  margin: 0;
    }

    /* demote h4 inside container-list notes */
    .print-record h4 {
      font-size: 90%;
      font-weight: normal;
      font-style: italic;
      margin: 0.2em 0 0.1em 0;
    }

    /* note text smaller than AO title */
    .print-record p {
      font-size: 90%;
      margin: 0;
    }

    .print-record dl {
  margin: 0 0 0.5em 0;
    }


    .italic {
  font-style: italic;
    }

    .inherit {
  font-style: italic;
    }

    .print-record-border a.record-title {
  color: black;
  font-weight: normal;
    }

    .box-area {
       /* margin-top: 5px; */
       display: block;
       width: 250px;
    }

    .box-string {
       float: left;
       text-align: left;
       margin-right: 10px;
       overflow: scroll;
    }

    .folder-string {
       float: right;
       margin-left: 10px;
       overflow: scroll;
    }
    .first-post {
       background-color: #eee;
       padding-top: 10px;
       padding-bottom: 10px;
    }

    .print-record-border.first-post a.record-title {
       font-weight: bold !important;
    }

    .indented dl,
    .indented a {
      font-size: 85%;
    }

    .indented dt,
    .indented dd { margin-top: 0.1em; }

    }

    <%# Hide headers/footers on the titlepage %>
    @page :first {
  @top-center {
      content: '';
  }

  @bottom-center {
      content: '';
  }
    }

    @page {
       <% if @resource.finding_aid['title'] %>
   <% short_title = @resource.finding_aid['title'] %>
       <% else %>
   <% short_title = @resource.display_string %>
       <% end %>

  <% if short_title != '' %>
  @top-center {
      font-size: 80%;
      color: #666;
      content: '<%= short_title %>';
  }
  <% end %>

  @bottom-center {
      font-size: 80%;
      color: #666;
      content: '- Page ' counter(page) ' -';
  }
    }

  </style>
</head>
