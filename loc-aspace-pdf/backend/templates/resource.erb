<a id="summary-information"></a>
<h3><%= I18n.t('pdf_reports.summary_information') %></h3>

<dl>
    <dt><%= I18n.t('repository._singular') %>:</dt>
    <dd><%= @resource.resolved_repository['name'] %></dd>

    <% if @resource.agents %>
	<% @resource.agents.each do |role, relationships| %>
	    <% relationships.each do |relationship| %>
		<% if role != "subject" %>
		  <dt><%= I18n.t('enumerations.linked_agent_role.' + role.to_s) %></dt>
		  <dd><%= relationship['_resolved']['title'] %></dd>
		<% end %>
	    <% end %>
	<% end %>
    <% end %>

    <dt><%= I18n.t('resource._public.finding_aid.title') %>:</dt><dd><%= process_mixed_content(@resource.display_string) %></dd>

    <dt><%= I18n.t('resource._public.identifier_pdf') %>:</dt><dd><%= @resource.identifier %></dd>

    <% if @resource['ark_name'] %>
      <dt><%= I18n.t('resource._public.identifier_ark') %>:</dt><dd><a href='<%= @resource['ark_name'].first %>'>Archival Resource Key</a></dd>

    <% end %>

    <dt><%= I18n.t('resource._public.uri') %>:</dt>
    <dd><%= @resource['uri'] %></dd>

    <% @resource.dates.each do |date| %>
	<dt><%= I18n.t('resource._public.finding_aid.date') + " [#{date['date_type']}]" %>:</dt><dd><%= date['final_expression'].split(':')[1].chomp %></dd>
    <% end %>

    <% @resource.extents.each do |extent| %>
	<dt><%= I18n.t('resource._public.physdesc') %>:</dt><dd><%= extent['display'] %></dd>
    <% end %>

    <% unless @resource.notes.include?('langmaterial') || @resource.lang_materials.blank? %>
	<dt><%= t('resource._public.lang_pdf') %>:</dt>
	<% @resource.lang_materials.each do |lang_material| %>
	    <dd><%= t('enumerations.language_iso639_2.' + lang_material['language'])%></dd>
	<% end %>
    <% end %>

    <% @resource.notes.each do |note_type, note| %>
	<% if %w(physdesc langmaterial physloc note_type abstract).include?(note_type) %>
	    <a id="note-<%= note_type %>"></a>
	    <% note.each do |n| %>
	      <dt><%= n['label'] ? n['label'] : I18n.t("enumerations._note_types.#{note_type}", default: note_type) %>:</dt><dd><%= n['note_text'] %></dd>
	    <% end %>
	<% end %>
    <% end %>

    <% if @resource.container_display && !@resource.container_display.empty? %>
	<dt><%= I18n.t('resource._public.storage') %>:</dt><dd><%= @resource.container_display.join(', ') %></dd>
    <% end %>

    <!-- digital_object instances -->
    <%= yield %>

</dl>

    <a href="#toc"><%= I18n.t('pdf_reports.return_to_table_of_contents') %></a>

    <% @resource.notes.each do |note_type, note| %>
	<% if note_type == 'prefercite' %>
	    <a id="note-prefercite"></a>
	    <% note.each do |n| %>
	      <div id="note-prefercite">
		<dl><dt><%= n['label'] ? n['label'] : I18n.t("enumerations._note_types.prefercite") %>:</dt><dd><%= n['note_text'] %></dd></dl>
	      </div>
	    <% end %>
	<% end %>
    <% end %>

<div class='bioghist'>
  <a id="note-bioghist"></a>
  <% unless @resource.notes['bioghist'].nil? %>
    <% @resource.notes['bioghist'].each do |n| %>
	<h3>
	  <% if n['label'] %>
	      <%= process_mixed_content(n['label']) %>
	  <% else %>
	      <%= I18n.t("enumerations._note_types.bioghist") %>
	  <% end %>
	</h3>
      <p><%= n['note_text'].html_safe %></p>
    <% end %>
  <% end %>

  <a href="#toc"><%= I18n.t('pdf_reports.return_to_table_of_contents') %></a>
</div>


