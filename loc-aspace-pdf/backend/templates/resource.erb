<% end %>


<% unless @resource.subjects.empty? %>
  <a id="controlled-access-headings"></a>
  <h3><%= I18n.t('pdf_reports.controlled_access_headings') %></h3>

  <ul>
    <% Array(@resource.subjects).each do |subject| %>
	<li><%= subject['title'] %></li>
    <% end %>

    <% if @resource.agents %>
	<% @resource.agents.each do |role, relationships| %>
	    <% relationships.each do |relationship| %>
		<% if role == "subject" %>
		  <li><%= relationship['_resolved']['title'] %></li>
		<% end %>
	    <% end %>
	<% end %>
    <% end %>


  </ul>

  <a href="#toc"><%= I18n.t('pdf_reports.return_to_table_of_contents') %></a>
<% end %>


