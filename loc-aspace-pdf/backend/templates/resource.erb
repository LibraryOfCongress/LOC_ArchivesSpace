<a id="administrative-information"></a>
<h3><%= I18n.t('pdf_reports.administrative_information') %></h3>

<h4><%= I18n.t('pdf_reports.publication_statement') %></h4>
<div class="repository-information">
    <% if @resource.resolved_repository['name'] %>
      <div class="repository-name"><%= @resource.resolved_repository['name'] %></div>
	<div class="repository-address">
      </div>
    <% end %>
    <% if @resource.repository_information['email'] %>
	<div class="repository-email"><a href="mailto:<%= repository_information['email'] %>"><%= @resource.repository_information['email'] %></a></div>
    <% end %>
    <% if @resource.repository_information['top']['url'] %>
	<div class="repository-url">
	    URL: <a href="<%= repository_information['top']['url'] %>"><%= @resource.repository_information['top']['url'] %></a>
	</div>
    <% end %>
</div>

<% if @resource.resolved_repository &&
      @resource.resolved_repository['agent_representation'].any? &&
      @resource.resolved_repository['agent_representation']['_resolved'].any? &&
      @resource.resolved_repository['agent_representation']['_resolved']['agent_contacts'].any? %>
    <% contacts = @resource.resolved_repository['agent_representation']['_resolved']['agent_contacts'].first %>
<% else %>
    <% contacts = nil %>
<% end %>


<div class="repository-information">
  <div class="repository-address"><%= @resource.resolved_repository['name'] %></div>

  <% if contacts %>
    <div class="repository-address">
      <% if contacts['address_1'] %>
	<p><%= contacts['address_1'] %></p>
      <% end %>

      <% if contacts['address_2'] %>
	<p><%= contacts['address_2'] %></p>
      <% end %>

      <% if contacts['address_3'] %>
	<p><%= contacts['address_3'] %></p>
      <% end %>

      <% address_string = "" %>
      <% address_string += contacts['city'] if contacts['city'] %>
      <% address_string += ", #{contacts['region']}" if contacts['region'] %>
      <% address_string += " #{contacts['post_code']}" if contacts['post_code'] %>

      <% unless address_string.empty? %>
	<p><%= address_string %></p>
      <% end %>
    </div>
  <% end %>
</div>
<br />

<% if @resource.finding_aid['revision'].length > 0 %>
  <h4><%= I18n.t('revision_statement.description') %></h4>
  <% @resource.finding_aid['revision'].each do |rev| %>
    <p><%= rev['desc'] %></p>
  <% end %>
<% end %>

<%# display all notes %>

<% @resource.notes.each do |note_type, note| %>
  <% next if note_type == "bioghist" %>
  <% next if note_type == "scopecontent" %>
  <% next if note_type == "relatedmaterial" %>
  <% next if note_type == "odd" %>
  <% next if note_type == "arrangement" %>
  <% next if note_type == "prefercite" %>

  <% @resource.notes[note_type].each do |n| %>
    <% next unless n['subnotes'] %>
    <% n['subnotes'].each do |sn| %>
      <% next unless sn['content'] %>
      <h4><%= I18n.t("enumerations._note_types.#{note_type}", default: note_type) %></h4>
      <p><%= simple_format(sn['content']) %></p>
    <% end %>
  <% end %>
<% end %>

<a href="#toc"><%= I18n.t('pdf_reports.return_to_table_of_contents') %></a>

