<div class="title-page">
    <div class="logo"><%= image_tag( @resource.resolved_repository['image_url'] || asset_path("ArchivesSpaceLogo_for_pdf.png") ) %></div>
    <div class="title-block">

    <% if @resource.finding_aid['title'] %>
      <% title_string = @resource.finding_aid['title'] %>
    <% elsif @resource.finding_aid['filing_title'] %>
      <% title_string = @resource.finding_aid['filing_title'] %>
    <% else %>
      <% title_string = @resource.display_string %>
    <% end %>

    <h1 class="title"><%= process_mixed_content(title_string, :preserve_newlines => true) %></h1>
    <h4 class="subtitle"><%= if @resource.finding_aid['subtitle'] then process_mixed_content(@resource.finding_aid['subtitle'], :preserve_newlines => true) end %></h4>

    <hr />
    </div>

    <div class="title-text-block">
    <p><%= I18n.t('pdf_reports.finding_aid_date_prefix') %> <%= Date.today.strftime("%B %d, %Y") + "." %></p>

    <% if @resource.finding_aid['script'] %>
      <% script_declaration = " (#{t('enumerations.script_iso15924.' + @resource.finding_aid['script'])})" %>
    <% else %>
      <% script_declaration = "" %>
    <% end %>


    <% if @resource.finding_aid['language_note'] %>
      <p><%= @resource.finding_aid['language_note'] %></p>
    <% elsif @resource.finding_aid['language'] %>
  <p><%= "Description is written in: " + t('enumerations.language_iso639_2.' + @resource.finding_aid['language']) + script_declaration + "." %></p>
    <% end %>

    <% if @resource.finding_aid['description_rules'] %>
  <p><%= I18n.t('enumerations.resource_finding_aid_description_rules.' + @resource.finding_aid['description_rules'], :default => @resource.finding_aid['description_rules']) %></p>
    <% end %>

    <p><%= @resource.finding_aid['edition_statement'] %></p>
    </div>

    <% if @resource.resolved_repository &&
    @resource.resolved_repository['agent_representation'].any? &&
    @resource.resolved_repository['agent_representation']['_resolved'].any? &&
    @resource.resolved_repository['agent_representation']['_resolved']['agent_contacts'].any? %>
  <% contacts = @resource.resolved_repository['agent_representation']['_resolved']['agent_contacts'].first %>
    <% else %>
  <% contacts = nil %>
    <% end %>

    <div class="repository-information">
      <div class="repository-name"><%= @resource.resolved_repository['name'] %></div>

      <% if contacts %>
  <div class="repository-address">
      <p><%= contacts['address_1'] %></p>
      <p><%= contacts['address_2'] %></p>
      <p><%= contacts['address_3'] %></p>

      <% address_string = "" %>
      <% address_string += contacts['city'] if contacts['city'] %>
      <% address_string += ", #{contacts['region']}" if contacts['region'] %>
      <% address_string += " #{contacts['post_code']}" if contacts['post_code'] %>

      <p><%= address_string %></p>
  </div>
      <% end %>

      <% if @resource.repository_information['email'] %>
    <div class="repository-email"><a href="mailto:<%= @resource.repository_information['email'] %>"><%= @resource.repository_information['email'] %></a></div>
      <% end %>
      <% if @resource.repository_information['top']['url'] %>
    <div class="repository-url">
        URL: <a href="<%= @resource.repository_information['top']['url'] %>"><%= @resource.repository_information['top']['url'] %></a>
    </div>
      <% end %>
    </div>
</div>
