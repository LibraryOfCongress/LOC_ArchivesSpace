<% Array(note['content']).each do |content| %>
  <%= process_mixed_content(content) %>
  <br/>
<% end %>

<dl>
  <% Array(note['items']).each do |index_item| %>
    <dt><%= process_mixed_content( index_item['value'] ) %></dt>
    <dd><%= index_item['reference'] %></dd>
    <dd><%= index_item['reference_text'] %></dd>
  <% end %>
</dl>
