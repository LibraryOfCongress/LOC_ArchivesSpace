<% define_template "note_unorderedlist", jsonmodel_definition(:note_unorderedlist) do |form| %>
  <div class="subrecord-form-fields" data-type="note_unorderedlist">
    <h3 class="subrecord-form-heading"><%= t("note.note_unorderedlist") %></h3>
    <div class="subrecord-form-container">
      <%= form.hidden_input(:jsonmodel_type, "note_unorderedlist") %>
      <%= form.hidden_input("ingest_problem") %>
      <%= form.label_and_textfield("title") %>
      <%= form.label_and_select("enumeration", form.possible_options_for("enumeration", true)) %>
      <%= form.label_and_boolean("publish", {}, user_prefs["publish"]) %>

      <div class="form-group">
        <label class="control-label"><%= t("note_unorderedlist.items") %></label>
        <div class="controls">
          <%= form.list_for(form["items"], "items[]") do |item| %>
            <% form.emit_template("unorderedlist_item", item) %>
          <% end %>
          <% if not form.readonly? %>
            <button class="btn btn-sm btn-default add-item-btn"><%= t("note._frontend.action.add_note_unorderedlist") %></button>
          <% end %>
        </div>
      </div>

    </div>
  </div>
<% end %>

<% define_template "unorderedlist_item" do |form, item| %>
  <div class="subrecord-form-inline"><%= form.textfield(nil, item, :escape => false) %></div>
<% end %>
